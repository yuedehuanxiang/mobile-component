{
  "name": "deepseek-test",
  "private": true,
  "version": "0.0.0",
  "description": "Vue 2 + Vite mobile component project with 375-based rem adaptation",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0",
    "build": "vite build",
    "electron:dev": "electron .",
    "electron:pack:mac": "electron-builder --mac",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.mobilecomponent.releasebuilder",
    "productName": "Release Builder",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "electron/**/*",
      "scripts/**/*",
      "src/**/*",
      "index.html",
      "package.json",
      "vite.config.js",
      "postcss.config.cjs"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "amfe-flexible": "^2.2.1",
    "vue": "^2.7.16",
    "vue-router": "^3.6.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue2": "^2.3.3",
    "electron": "^41.7.1",
    "electron-builder": "^24.13.3",
    "less": "^4.6.4",
    "postcss-pxtorem": "^6.1.0",
    "vite": "^5.4.0"
  }
}
